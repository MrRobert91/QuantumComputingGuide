# Copy to .env and fill in. All values are optional for local Aer-only use.

# IBM Quantum Platform API token. When set, the app offers an "IBM Quantum" execution mode.
# Get one at https://quantum.ibm.com/ (My account -> API token).
IBM_QUANTUM_TOKEN=

# Optional IBM Quantum channel/instance overrides.
IBM_QUANTUM_CHANNEL=ibm_quantum_platform
IBM_QUANTUM_INSTANCE=

# CORS: comma-separated list of allowed frontend origins (dev defaults below).
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost

# Sandbox limits for user-submitted Qiskit code.
SANDBOX_TIMEOUT_SECONDS=10
SANDBOX_MAX_MEMORY_MB=512

# FRONTEND: base origin of the backend that nginx proxies /api to.
# No trailing slash, no /api. Used by the frontend container at startup.
#   docker compose:        http://backend:8000  (default)
#   separate deploy:       https://your-backend.sliplane.app
BACKEND_URL=http://backend:8000
